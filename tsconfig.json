{
	"include": [
		"replication/**/*",
		"security/**/*",
		"licensing/**/*",
		"analytics/**/*",
		"bin/**/*",
		"core/agent/**/*",
		"core/bin/**/*",
		"core/components/**/*",
		"core/config/**/*",
		"core/dataLayer/**/*",
		"core/json/**/*",
		"core/launchServiceSCripts/**/*",
		"core/resources/**/*",
		"core/security/**/*",
		"core/server/**/*",
		"core/sqlTranslator/**/*",
		"core/upgrade/**/*",
		"core/utility/**/*",
		"core/validation/**/*",
		"core/globals.js",
		"core/index.ts"
	],
	"compilerOptions": {
		// Allow JS files for mixed codebase
		"allowJs": true,
		"outDir": "dist",
		"esModuleInterop": true,
		"noImplicitAny": false,
		// Codebase is not strict-clean yet; pin explicitly so a compiler upgrade
		// that flips this default (e.g. TypeScript 7) doesn't silently change results
		"strict": false,
		"target": "ES2022",
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"sourceMap": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"allowImportingTsExtensions": true,

		// Allow .ts extensions in imports (will be transpiled to .js by esbuild)
		"rewriteRelativeImportExtensions": true,

		// Enforce erasable syntax only so we can use Node.js type-stripping
		"erasableSyntaxOnly": true,

		// Required: third-party type declarations (alasql, mathjs, msgpackr) have incompatible type errors
		"skipLibCheck": true,

		// TS7 removes baseUrl; paths are already relative to this file so this
		// resolves identically without it (verified: 0 resolution changes)
		"paths": {
			// Provide convenient path alias for compiled output
			// Change this to ./* once we're fully in TypeStrip land
			"@/*": ["./dist/*"]
		}
	}
}
